# Banco (Neon — connection string com pooler)
DATABASE_URL=""

# NextAuth — gerar com: openssl rand -base64 32 (mínimo 32 caracteres)
AUTH_SECRET=""

# Rate limit do login (Upstash). Opcional em dev; obrigatório em produção.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Seed do usuário único: npm run db:seed:admin --workspace apps/web
# SEED_SENHA: mínimo 12 caracteres (máx. 72 bytes — limite do bcrypt).
SEED_EMAIL=""
SEED_SENHA=""

# Token estático do app Android para POST /api/capturas (mín. 32 chars).
# Gerar com: openssl rand -hex 32. Ausente = endpoint desativado (503).
CAPTURA_SMS_TOKEN=""
